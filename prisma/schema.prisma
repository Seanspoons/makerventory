generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum PrinterStatus {
  ACTIVE
  MAINTENANCE
  OFFLINE
  ARCHIVED
}

enum MaterialSystemType {
  AMS_LITE
  AMS_2_PRO
  AMS_HT
  DRYER
}

enum MaterialSystemStatus {
  ACTIVE
  STANDBY
  MAINTENANCE
  OFFLINE
  ARCHIVED
}

enum BuildPlateStatus {
  AVAILABLE
  IN_USE
  WORN
  RETIRED
}

enum HotendStatus {
  AVAILABLE
  IN_USE
  LOW_STOCK
  RETIRED
}

enum StockStatus {
  HEALTHY
  LOW
  OUT
  ARCHIVED
}

enum SafetyStatus {
  ACTIVE
  NEEDS_ATTENTION
  PLANNED
  ARCHIVED
}

enum SmartPlugStatus {
  ONLINE
  OFFLINE
  DISABLED
}

enum WishlistPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum WishlistStatus {
  PLANNED
  RESEARCHING
  READY_TO_BUY
  PURCHASED
}

enum MaintenanceActionType {
  NOZZLE_SWAP
  LUBRICATION
  BED_CLEANING
  WIPER_REPLACEMENT
  PTFE_REPLACEMENT
  DESICCANT_REFRESH
  EXHAUST_UPDATE
  INSPECTION
  FIRMWARE_REVIEW
  OTHER
}

enum FilamentHygroscopicLevel {
  LOW
  MEDIUM
  HIGH
}

enum ImportEntityType {
  FILAMENT
  CONSUMABLE
  TOOL_PART
  WISHLIST
}

enum ImportJobStatus {
  STAGED
  APPLIED
  FAILED
}

enum ImportRowStatus {
  NEW
  MATCHED
  CONFLICT
  SKIPPED
  APPLIED
  ERROR
}

enum ImportRowResolution {
  CREATE_NEW
  UPDATE_MATCH
  SKIP
}

enum AuditActionType {
  CREATE
  UPDATE
  ARCHIVE
  VOID
  IMPORT_STAGE
  IMPORT_APPLY
}

model User {
  id                String            @id @default(cuid())
  name              String?
  email             String            @unique
  emailVerified     DateTime?
  image             String?
  passwordHash      String?
  isActive          Boolean           @default(true)
  sessionVersion    Int               @default(0)
  activeWorkspaceId String?
  activeWorkspace   Workspace?        @relation("ActiveWorkspace", fields: [activeWorkspaceId], references: [id], onDelete: SetNull)
  memberships       WorkspaceMember[]
  accounts          Account[]
  sessions          Session[]
  importJobs        ImportJob[]
  auditEvents       AuditEvent[]
  passwordResetTokens PasswordResetToken[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
}

model Workspace {
  id              String            @id @default(cuid())
  name            String
  slug            String            @unique
  description     String?           @db.Text
  activeUsers     User[]            @relation("ActiveWorkspace")
  memberships     WorkspaceMember[]
  printers        Printer[]
  materialSystems MaterialSystem[]
  buildPlates     BuildPlate[]
  hotends         Hotend[]
  filamentSpools  FilamentSpool[]
  consumables     ConsumableItem[]
  safetyEquipment SafetyEquipment[]
  smartPlugs      SmartPlug[]
  toolsParts      ToolPart[]
  wishlistItems   WishlistItem[]
  maintenanceLogs MaintenanceLog[]
  importJobs      ImportJob[]
  importRows      ImportRow[]
  auditEvents     AuditEvent[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceRole @default(MEMBER)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([workspaceId, userId])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model ImportJob {
  id               String          @id @default(cuid())
  workspaceId      String
  workspace        Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdByUserId  String
  createdByUser    User            @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  entityType       ImportEntityType
  status           ImportJobStatus @default(STAGED)
  sourceName       String
  originalFilename String
  notes            String?         @db.Text
  fieldMapping     Json?
  totalRows        Int             @default(0)
  newRows          Int             @default(0)
  matchedRows      Int             @default(0)
  conflictRows     Int             @default(0)
  skippedRows      Int             @default(0)
  appliedAt        DateTime?
  rows             ImportRow[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([workspaceId, createdAt])
}

model ImportRow {
  id                 String          @id @default(cuid())
  workspaceId        String
  workspace          Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  importJobId        String
  importJob          ImportJob       @relation(fields: [importJobId], references: [id], onDelete: Cascade)
  rowIndex           Int
  entityType         ImportEntityType
  status             ImportRowStatus @default(NEW)
  resolution         ImportRowResolution @default(CREATE_NEW)
  fingerprint        String
  suggestedMatchId   String?
  suggestedMatchSlug String?
  resolvedMatchId    String?
  resolvedMatchSlug  String?
  data               Json
  validationErrors   String[]
  appliedAt          DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@unique([importJobId, rowIndex])
  @@index([workspaceId, status])
}

model AuditEvent {
  id          String          @id @default(cuid())
  workspaceId String
  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorUserId String?
  actorUser   User?           @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actionType  AuditActionType
  entityType  String
  entityId    String?
  entityLabel String?
  summary     String
  metadata    Json?
  createdAt   DateTime        @default(now())

  @@index([workspaceId, createdAt])
  @@index([workspaceId, actionType])
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, expiresAt])
}

model RateLimitBucket {
  id         String   @id @default(cuid())
  action     String
  identifier String
  bucketStart DateTime
  count      Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([action, identifier, bucketStart])
  @@index([action, identifier])
}

model Printer {
  id                         String                 @id @default(cuid())
  workspaceId                String
  workspace                  Workspace              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                       String
  slug                       String
  brand                      String
  model                      String
  status                     PrinterStatus          @default(ACTIVE)
  buildVolumeX               Int
  buildVolumeY               Int
  buildVolumeZ               Int
  location                   String?
  notes                      String?                @db.Text
  imageUrl                   String?
  smartPlugId                String?                @unique
  smartPlug                  SmartPlug?             @relation(fields: [smartPlugId], references: [id])
  installedHotendId          String?                @unique
  installedHotend            Hotend?                @relation("InstalledHotend", fields: [installedHotendId], references: [id])
  installedPlateId           String?                @unique
  installedPlate             BuildPlate?            @relation("InstalledPlate", fields: [installedPlateId], references: [id])
  materialSystems            MaterialSystem[]
  compatiblePlates           PrinterBuildPlate[]
  compatibleHotends          PrinterHotend[]
  compatibleMaterialSystems  PrinterMaterialSystem[]
  maintenanceLogs            MaintenanceLog[]
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt

  @@unique([workspaceId, slug])
}

model MaterialSystem {
  id                      String               @id @default(cuid())
  workspaceId             String
  workspace               Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                    String
  slug                    String
  type                    MaterialSystemType
  supportedMaterialsNotes String?              @db.Text
  status                  MaterialSystemStatus @default(ACTIVE)
  notes                   String?              @db.Text
  imageUrl                String?
  assignedPrinterId       String?
  assignedPrinter         Printer?             @relation(fields: [assignedPrinterId], references: [id])
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  maintenanceLogs         MaintenanceLog[]
  compatiblePrinters      PrinterMaterialSystem[]

  @@unique([workspaceId, slug])
}

model BuildPlate {
  id                 String             @id @default(cuid())
  workspaceId        String
  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name               String
  slug               String
  sizeLabel          String
  sizeMm             Int
  surfaceType        String
  status             BuildPlateStatus   @default(AVAILABLE)
  notes              String?            @db.Text
  imageUrl           String?
  compatiblePrinters PrinterBuildPlate[]
  installedOnPrinter Printer?           @relation("InstalledPlate")
  maintenanceLogs    MaintenanceLog[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([workspaceId, slug])
}

model Hotend {
  id                 String             @id @default(cuid())
  workspaceId        String
  workspace          Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name               String
  slug               String
  nozzleSize         Decimal            @db.Decimal(4, 2)
  materialType       String
  quantity           Int                @default(1)
  inUseCount         Int                @default(0)
  spareCount         Int                @default(0)
  status             HotendStatus       @default(AVAILABLE)
  notes              String?            @db.Text
  imageUrl           String?
  compatiblePrinters PrinterHotend[]
  installedOnPrinter Printer?           @relation("InstalledHotend")
  maintenanceLogs    MaintenanceLog[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([workspaceId, slug])
}

model FilamentSpool {
  id                      String                    @id @default(cuid())
  workspaceId             String
  workspace               Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  brand                   String
  productLine             String?
  materialType            String
  subtype                 String?
  finish                  String?
  color                   String
  quantity                Int                       @default(1)
  estimatedRemainingGrams Int?
  spoolWeightGrams        Int?                      @default(1000)
  compatibilityTags       String[]
  dryingRequired          Boolean?
  abrasive                Boolean?                  @default(false)
  hygroscopicLevel        FilamentHygroscopicLevel?
  storageLocation         String?
  purchaseSource          String?
  status                  StockStatus               @default(HEALTHY)
  opened                  Boolean                   @default(false)
  nearlyEmpty             Boolean                   @default(false)
  notes                   String?                   @db.Text
  imageUrl                String?
  filamentRecommendation  FilamentRecommendation?
  createdAt               DateTime                  @default(now())
  updatedAt               DateTime                  @updatedAt
}

model FilamentRecommendation {
  id                   String        @id @default(cuid())
  filamentId           String        @unique
  filament             FilamentSpool @relation(fields: [filamentId], references: [id], onDelete: Cascade)
  recommendedNozzle    String?
  dryerSuggested       Boolean       @default(false)
  hardenedNozzleNeeded Boolean       @default(false)
  notes                String?       @db.Text
}

model ConsumableItem {
  id                String                     @id @default(cuid())
  workspaceId       String
  workspace         Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name              String
  slug              String
  category          String
  quantity          Decimal                    @db.Decimal(10, 2)
  unit              String
  reorderThreshold  Decimal                    @db.Decimal(10, 2)
  status            StockStatus                @default(HEALTHY)
  storageLocation   String?
  notes             String?                    @db.Text
  imageUrl          String?
  maintenanceUsages MaintenanceConsumableUsage[]
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@unique([workspaceId, slug])
}

model SafetyEquipment {
  id                  String          @id @default(cuid())
  workspaceId         String
  workspace           Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                String
  slug                String
  type                String
  status              SafetyStatus    @default(ACTIVE)
  replacementSchedule String?
  notes               String?         @db.Text
  imageUrl            String?
  maintenanceLogs     MaintenanceLog[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@unique([workspaceId, slug])
}

model SmartPlug {
  id                     String          @id @default(cuid())
  workspaceId            String
  workspace              Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                   String
  slug                   String
  status                 SmartPlugStatus @default(ONLINE)
  assignedDeviceLabel    String?
  powerMonitoringCapable Boolean         @default(false)
  notes                  String?         @db.Text
  printer                Printer?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  @@unique([workspaceId, slug])
}

model ToolPart {
  id              String    @id @default(cuid())
  workspaceId     String
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name            String
  slug            String
  category        String
  quantity        Int       @default(1)
  storageLocation String?
  notes           String?   @db.Text
  imageUrl        String?
  archivedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([workspaceId, slug])
  @@index([workspaceId, archivedAt])
}

model WishlistItem {
  id            String           @id @default(cuid())
  workspaceId   String
  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  slug          String
  category      String
  priority      WishlistPriority
  estimatedCost Decimal?         @db.Decimal(10, 2)
  vendor        String?
  purchaseUrl   String?
  notes         String?          @db.Text
  status        WishlistStatus   @default(PLANNED)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([workspaceId, slug])
}

model MaintenanceLog {
  id                String                     @id @default(cuid())
  workspaceId       String
  workspace         Workspace                  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  date              DateTime
  actionType        MaintenanceActionType
  actionPerformed   String
  notes             String?                    @db.Text
  printerId         String?
  printer           Printer?                   @relation(fields: [printerId], references: [id])
  materialSystemId  String?
  materialSystem    MaterialSystem?            @relation(fields: [materialSystemId], references: [id])
  buildPlateId      String?
  buildPlate        BuildPlate?                @relation(fields: [buildPlateId], references: [id])
  hotendId          String?
  hotend            Hotend?                    @relation(fields: [hotendId], references: [id])
  safetyEquipmentId String?
  safetyEquipment   SafetyEquipment?           @relation(fields: [safetyEquipmentId], references: [id])
  consumablesUsed   MaintenanceConsumableUsage[]
  voidedAt          DateTime?
  voidReason        String?                    @db.Text
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  @@index([workspaceId, voidedAt])
}

model MaintenanceConsumableUsage {
  id               String         @id @default(cuid())
  maintenanceLogId String
  maintenanceLog   MaintenanceLog @relation(fields: [maintenanceLogId], references: [id], onDelete: Cascade)
  consumableItemId String
  consumableItem   ConsumableItem @relation(fields: [consumableItemId], references: [id])
  quantityUsed     Decimal        @db.Decimal(10, 2)
  unit             String
}

model PrinterBuildPlate {
  id           String     @id @default(cuid())
  printerId    String
  buildPlateId String
  notes        String?
  printer      Printer    @relation(fields: [printerId], references: [id], onDelete: Cascade)
  buildPlate   BuildPlate @relation(fields: [buildPlateId], references: [id], onDelete: Cascade)

  @@unique([printerId, buildPlateId])
}

model PrinterHotend {
  id        String   @id @default(cuid())
  printerId String
  hotendId  String
  notes     String?
  printer   Printer  @relation(fields: [printerId], references: [id], onDelete: Cascade)
  hotend    Hotend   @relation(fields: [hotendId], references: [id], onDelete: Cascade)

  @@unique([printerId, hotendId])
}

model PrinterMaterialSystem {
  id               String         @id @default(cuid())
  printerId        String
  materialSystemId String
  notes            String?
  printer          Printer        @relation(fields: [printerId], references: [id], onDelete: Cascade)
  materialSystem   MaterialSystem @relation(fields: [materialSystemId], references: [id], onDelete: Cascade)

  @@unique([printerId, materialSystemId])
}
